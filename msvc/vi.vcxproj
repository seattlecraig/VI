  <!-- ============================================================ -->
  <!-- Compiler settings common to all configurations               -->
  <!-- ============================================================ -->
  <ItemDefinitionGroup>
    <ClCompile>
      <!--
        Include paths:
          ..\h    = main editor headers
          .       = msvc compat stubs (banner.h, clibext.h, dos.h, getopt.h, autoenv.h)
        The msvc\ directory is listed FIRST so our dos.h shim takes
        priority over any system dos.h.
      -->
      <AdditionalIncludeDirectories>$(ProjectDir);$(ProjectDir)..\h;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <!--
        Preprocessor defines:
          __NT__    = Target is Windows NT (activates Win32 console API code paths)
          __386__   = 32-bit x86 target (used by control.h and other platform guards)
          NOUSE3D   = Disable 3D UI controls (from original makefile)
          _CRT_SECURE_NO_WARNINGS = Suppress MSVC deprecation warnings for standard C functions
          _CRT_NONSTDC_NO_DEPRECATE = Suppress warnings for POSIX function names
      -->
      <PreprocessorDefinitions>__NT__;__386__;NOUSE3D=1;_CRT_SECURE_NO_WARNINGS;_CRT_NONSTDC_NO_DEPRECATE;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <CompileAs>CompileAsC</CompileAs>
      <!-- Treat all source as C, not C++ -->
      <WarningLevel>Level3</WarningLevel>
      <ConformanceMode>false</ConformanceMode>
      <!--
        Disable specific warnings that will fire on this legacy codebase:
          4013 = 'function' undefined; assuming extern returning int
          4018 = signed/unsigned mismatch
          4024 = different types for formal and actual parameter
          4047 = differs in levels of indirection
          4090 = different 'const' qualifiers
          4100 = unreferenced formal parameter
          4101 = unreferenced local variable
          4113 = actual parameter lists differ
          4133 = incompatible types
          4146 = unary minus operator applied to unsigned type
          4244 = conversion from 'type1' to 'type2', possible loss of data
          4267 = conversion from 'size_t' to 'type', possible loss of data
      -->
      <DisableSpecificWarnings>4013;4018;4024;4047;4090;4100;4101;4113;4133;4146;4244;4267;%(DisableSpecificWarnings)</DisableSpecificWarnings>
      <!--
        Force include our dos.h compatibility header so it is seen before
        the system dos.h wherever #include <dos.h> appears in the code.
      -->
      <ForcedIncludeFiles>%(ForcedIncludeFiles)</ForcedIncludeFiles>
      <MultiProcessorCompilation>true</MultiProcessorCompilation>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
      <AdditionalDependencies>kernel32.lib;user32.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <StackReserveSize>131072</StackReserveSize>
    </Link>
  </ItemDefinitionGroup>

  <!-- Debug-specific overrides -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <RuntimeLibrary Condition="'$(Platform)'=='Win32'">MultiThreadedDebug</RuntimeLibrary>
      <RuntimeLibrary Condition="'$(Platform)'=='x64'">MultiThreadedDebug</RuntimeLibrary>
      <PreprocessorDefinitions>_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
