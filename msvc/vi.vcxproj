<?xml version="1.0" encoding="utf-8"?>
<!--
  Visual Studio project for Open Watcom VI editor - NT Console (character mode) build.

  This replicates the nt386 makefile target: a Windows console application
  using Win32 Console APIs for screen/keyboard/mouse I/O.

  Source directories:
    ..\c\     - Core editor source (~105 files)
    ..\nt\    - NT platform layer (7 files)
    ..\ui\    - Character-mode UI (20 files)
    .\        - MSVC compatibility stubs (getopt.c, autoenv.c)

  Header directories:
    ..\h\     - Main editor headers
    .\        - MSVC compat headers (banner.h, clibext.h, dos.h, getopt.h, autoenv.h)
-->
